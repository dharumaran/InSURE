# Production / `vite build`: full API origin (no trailing slash).
# Local `vite`: leave unset — requests use /api and Vite proxies to http://127.0.0.1:3001
# VITE_API_URL=https://shieldride-api.vercel.app
#
# Optional: hit a remote API while using `vite` dev (bypasses proxy). Rare.
# VITE_DEV_API_URL=https://shieldride-api.vercel.app
VITE_MOCK_SENSORS=true
VITE_ANTHROPIC_API_KEY=
VITE_FIREBASE_CONFIG=

